# /etc/sudoers.d/ft8-self-update — rendered by deploy/install.sh
#
# Allows the appliance user a very small set of root operations for
# self-update, controller restart and system-file sync.

@APP_USER@ ALL=(root) NOPASSWD: \
    /bin/systemctl restart ft8-controller, \
    /bin/systemctl restart ft8-controller.service, \
    /bin/systemctl start ft8-controller, \
    /bin/systemctl start ft8-controller.service, \
    /bin/systemctl is-active ft8-controller, \
    /bin/systemctl is-active ft8-controller.service, \
    /bin/systemctl start ft8-self-update, \
    /bin/systemctl start ft8-self-update.service, \
    /bin/systemctl start --no-block ft8-self-update.service, \
    /bin/systemctl daemon-reload

@APP_USER@ ALL=(root) NOPASSWD: \
    /sbin/shutdown -h +0 *, \
    /sbin/shutdown -r +0 *

@APP_USER@ ALL=(root) NOPASSWD: \
    /usr/bin/install -m 644 @APP_DIR@/.deploy-rendered/systemd/ft8-controller.service /etc/systemd/system/ft8-controller.service, \
    /usr/bin/install -m 644 @APP_DIR@/.deploy-rendered/systemd/ft8-self-update.service /etc/systemd/system/ft8-self-update.service, \
    /usr/bin/install -m 644 @APP_DIR@/.deploy-rendered/systemd/ft8-self-update.timer /etc/systemd/system/ft8-self-update.timer, \
    /usr/bin/install -m 644 @APP_DIR@/.deploy-rendered/systemd/ft8-ap-fallback.service /etc/systemd/system/ft8-ap-fallback.service, \
    /usr/bin/install -m 644 @APP_DIR@/.deploy-rendered/systemd/ft8-rigctld.service /etc/systemd/system/ft8-rigctld.service, \
    /usr/bin/install -m 440 @APP_DIR@/.deploy-rendered/sudoers.d/ft8-self-update /etc/sudoers.d/ft8-self-update

@APP_USER@ ALL=(root) NOPASSWD: /usr/sbin/visudo -c -f @APP_DIR@/.deploy-rendered/sudoers.d/ft8-self-update, /usr/sbin/visudo -c -f /etc/sudoers.d/ft8-self-update
